{
  "info": {
    "name": "Moto Mini App Backend Cancel Flow",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    }
  ],
  "item": [
    {
      "name": "Run cancel flow",
      "request": {
        "method": "GET",
        "url": "{{baseUrl}}/api/health"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const baseUrl = pm.variables.get('baseUrl');",
              "const jsonHeaders = { 'Content-Type': 'application/json' };",
              "const stamp = Date.now();",
              "",
              "function send(method, path, body, cb) {",
              "  pm.sendRequest({",
              "    url: baseUrl + path,",
              "    method,",
              "    header: jsonHeaders,",
              "    body: body === undefined ? undefined : { mode: 'raw', raw: JSON.stringify(body) }",
              "  }, function (error, response) {",
              "    pm.expect(error).to.equal(null);",
              "    cb(response, response.json());",
              "  });",
              "}",
              "",
              "function createStudent(prefix, cb) {",
              "  send('POST', '/api/students', {",
              "    name: prefix + ' Student',",
              "    telegramUsername: prefix + '_' + stamp + '_' + Math.floor(Math.random() * 100000),",
              "    level: 'BEGINNER'",
              "  }, function (response, body) {",
              "    pm.expect(response.code).to.equal(201);",
              "    cb(body);",
              "  });",
              "}",
              "",
              "function createSlot(startsAt, cb) {",
              "  send('POST', '/api/booking-slots', { startsAt, durationMinutes: 90 }, function (response, body) {",
              "    pm.expect(response.code).to.equal(201);",
              "    cb(body);",
              "  });",
              "}",
              "",
              "function requestSlot(slotId, studentId, cb) {",
              "  send('POST', '/api/booking-slots/' + slotId + '/request', { studentId, preference: 'утро', studentComment: 'cancel flow' }, function (response, body) {",
              "    pm.expect(response.code).to.equal(201);",
              "    pm.expect(body.status).to.equal('requested');",
              "    cb(body);",
              "  });",
              "}",
              "",
              "function confirmSlot(slotId, cb) {",
              "  send('POST', '/api/booking-slots/' + slotId + '/confirm', { finalLocation: 'Учебная площадка', finalLocationUrl: 'https://maps.example.com/cancel', instructorComment: 'confirmed' }, function (response, body) {",
              "    pm.expect(response.code).to.equal(201);",
              "    pm.expect(body.status).to.equal('confirmed');",
              "    cb(body);",
              "  });",
              "}",
              "",
              "function assertAvailable(slot) {",
              "  pm.expect(slot.status).to.equal('available');",
              "  pm.expect(slot.studentId).to.equal(null);",
              "  ['preference', 'studentComment', 'finalLocation', 'finalLocationUrl', 'instructorComment', 'previousStartsAt', 'previousDurationMinutes'].forEach(function (field) {",
              "    pm.expect(slot[field], field).to.equal(null);",
              "  });",
              "}",
              "",
              "pm.test('health is ok', function () {",
              "  pm.response.to.have.status(200);",
              "",
              "createStudent('cancel_requested', function (student1) {",
              "  createSlot('2026-06-21T10:00:00.000Z', function (slot1) {",
              "    requestSlot(slot1.id, student1.id, function () {",
              "      send('POST', '/api/booking-slots/' + slot1.id + '/cancel', { reason: 'не получается приехать' }, function (response, cancelledRequested) {",
              "        pm.test('requested slot can be cancelled to available', function () {",
              "          pm.expect(response.code).to.equal(201);",
              "          assertAvailable(cancelledRequested);",
              "        });",
              "",
              "        createStudent('cancel_confirmed', function (student2) {",
              "          createSlot('2026-06-22T10:00:00.000Z', function (slot2) {",
              "            requestSlot(slot2.id, student2.id, function () {",
              "              confirmSlot(slot2.id, function () {",
              "                send('POST', '/api/booking-slots/' + slot2.id + '/cancel', {}, function (confirmedResponse, cancelledConfirmed) {",
              "                  pm.test('confirmed slot can be cancelled to available', function () {",
              "                    pm.expect(confirmedResponse.code).to.equal(201);",
              "                    assertAvailable(cancelledConfirmed);",
              "                  });",
              "                  send('GET', '/api/booking-slots?status=available', undefined, function (availableResponse, availableSlots) {",
              "                    pm.test('cancelled confirmed slot appears in available filter', function () {",
              "                      pm.expect(availableResponse.code).to.equal(200);",
              "                      pm.expect(availableSlots.some((slot) => slot.id === slot2.id)).to.equal(true);",
              "                    });",
              "",
              "                    createStudent('cancel_reschedule', function (student3) {",
              "                      createSlot('2026-06-23T10:00:00.000Z', function (slot3) {",
              "                        requestSlot(slot3.id, student3.id, function () {",
              "                          confirmSlot(slot3.id, function () {",
              "                            send('POST', '/api/booking-slots/' + slot3.id + '/reschedule', { startsAt: '2026-06-24T12:00:00.000Z', durationMinutes: 90, instructorComment: 'перенос' }, function () {",
              "                              send('POST', '/api/booking-slots/' + slot3.id + '/cancel', {}, function (rescheduleResponse, cancelledReschedule) {",
              "                                pm.test('reschedule slot can be cancelled and previous fields are cleared', function () {",
              "                                  pm.expect(rescheduleResponse.code).to.equal(201);",
              "                                  assertAvailable(cancelledReschedule);",
              "                                });",
              "",
              "                                createSlot('2026-06-25T10:00:00.000Z', function (availableSlot) {",
              "                                  send('POST', '/api/booking-slots/' + availableSlot.id + '/cancel', {}, function (availableFail) {",
              "                                    pm.test('available slot cannot be cancelled', function () {",
              "                                      pm.expect(availableFail.code).to.equal(409);",
              "                                    });",
              "",
              "                                    createStudent('cancel_completed', function (student4) {",
              "                                      createSlot('2026-06-26T10:00:00.000Z', function (slot4) {",
              "                                        requestSlot(slot4.id, student4.id, function () {",
              "                                          confirmSlot(slot4.id, function () {",
              "                                            send('POST', '/api/training-reports', { slotId: slot4.id, studentId: student4.id, trainedSkills: ['Овал'], improved: 'ok', nextFocus: 'next' }, function () {",
              "                                              send('POST', '/api/booking-slots/' + slot4.id + '/cancel', {}, function (completedFail) {",
              "                                                pm.test('completed slot cannot be cancelled', function () {",
              "                                                  pm.expect(completedFail.code).to.equal(409);",
              "                                                });",
              "                                              });",
              "                                            });",
              "                                          });",
              "                                        });",
              "                                      });",
              "                                    });",
              "                                  });",
              "                                });",
              "                              });",
              "                            });",
              "                            });",
              "                          });",
              "                        });",
              "                      });",
              "                    });",
              "                  });",
              "                });",
              "              });",
              "            });",
              "          });",
              "        });",
              "      });",
              "    });",
              "  });",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
